                "raw": "https://graph.threads.net/v1.0/{{threads_user_id}}/threads_insights?metric=views,likes,replies,reposts,quotes&period=day&access_token={{threads_token}}",
                "protocol": "https",
                "host": ["graph", "threads", "net"],
                "path": ["v1.0", "{{threads_user_id}}", "threads_insights"],
                "query": [
                  {
                    "key": "metric",
                    "value": "views,likes,replies,reposts,quotes"
                  },
                  {
                    "key": "period",
                    "value": "day"
                  },
                  {
                    "key": "access_token",
                    "value": "{{threads_token}}"
                  }
                ]
              }
            }
          },
          {
            "name": "4. Profile Lookup",
            "request": {
              "method": "GET",
              "header": [],
              "url": {
                "raw": "https://graph.threads.net/v1.0/profile_lookup?username=zuck&access_token={{threads_token}}",
                "protocol": "https",
                "host": ["graph", "threads", "net"],
                "path": ["v1.0", "profile_lookup"],
                "query": [
                  {
                    "key": "username",
                    "value": "zuck"
                  },
                  {
                    "key": "access_token",
                    "value": "{{threads_token}}"
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
