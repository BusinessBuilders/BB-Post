                "raw": "https://graph.instagram.com/v21.0/{{instagram_id}}/media_publish?creation_id={{media_container_id}}&access_token={{instagram_token}}",
                "protocol": "https",
                "host": ["graph", "instagram", "com"],
                "path": ["v21.0", "{{instagram_id}}", "media_publish"],
                "query": [
                  {
                    "key": "creation_id",
