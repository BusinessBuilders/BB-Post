                "protocol": "https",
                "host": ["graph", "facebook", "com"],
                "path": ["v21.0", "{{post_id}}", "comments"],
                "query": [
                  {
                    "key": "message",
                    "value": "Testing comment management"
                  },
                  {
                    "key": "access_token",
                    "value": "{{instagram_token}}"
                  }
                ]
              }
            }
          },
          {
            "name": "4. Get Account Insights",
            "request": {
              "method": "GET",
              "header": [],
              "url": {
                "raw": "https://graph.instagram.com/v21.0/{{instagram_id}}/insights?metric=follower_count,reach&period=day&access_token={{instagram_token}}",
                "protocol": "https",
                "host": ["graph", "instagram", "com"],
                "path": ["v21.0", "{{instagram_id}}", "insights"],
                "query": [
                  {
                    "key": "metric",
                    "value": "follower_count,reach"
                  },
                  {
                    "key": "period",
                    "value": "day"
                  },
                  {
                    "key": "access_token",
                    "value": "{{instagram_token}}"
                  }
                ]
              }
            }
          },
          {
            "name": "5. Get Engagement Insights",
            "request": {
              "method": "GET",
              "header": [],
              "url": {
                "raw": "https://graph.instagram.com/v21.0/{{instagram_id}}/insights?metric=likes,views,comments,shares,saves,replies&metric_type=total_value&period=day&access_token={{instagram_token}}",
                "protocol": "https",
                "host": ["graph", "instagram", "com"],
                "path": ["v21.0", "{{instagram_id}}", "insights"],
                "query": [
                  {
                    "key": "metric",
                    "value": "likes,views,comments,shares,saves,replies"
                  },
                  {
                    "key": "metric_type",
                    "value": "total_value"
                  },
                  {
                    "key": "period",
                    "value": "day"
                  },
                  {
                    "key": "access_token",
                    "value": "{{instagram_token}}"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "Threads Tests",
        "item": [
          {
            "name": "1. Create Thread",
            "request": {
              "method": "POST",
              "header": [],
              "body": {
                "mode": "formdata",
                "formdata": [
                  {
                    "key": "media_type",
                    "value": "TEXT",
                    "type": "text"
                  },
                  {
                    "key": "text",
                    "value": "Testing Threads API!",
                    "type": "text"
                  },
                  {
                    "key": "access_token",
                    "value": "{{threads_token}}",
                    "type": "text"
                  }
                ]
              },
              "url": {
                "raw": "https://graph.threads.net/v1.0/{{threads_user_id}}/threads",
                "protocol": "https",
                "host": ["graph", "threads", "net"],
                "path": ["v1.0", "{{threads_user_id}}", "threads"]
              }
            }
          },
          {
            "name": "2. Publish Thread",
            "request": {
              "method": "POST",
              "header": [],
              "url": {
                "raw": "https://graph.threads.net/v1.0/{{threads_user_id}}/threads_publish?creation_id={{thread_creation_id}}&access_token={{threads_token}}",
                "protocol": "https",
                "host": ["graph", "threads", "net"],
                "path": ["v1.0", "{{threads_user_id}}", "threads_publish"],
                "query": [
                  {
                    "key": "creation_id",
                    "value": "{{thread_creation_id}}"
                  },
                  {
                    "key": "access_token",
                    "value": "{{threads_token}}"
                  }
                ]
              }
            }
          },
          {
            "name": "3. Get Thread Insights",
            "request": {
              "method": "GET",
              "header": [],
